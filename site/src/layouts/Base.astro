---
import "@fontsource-variable/eb-garamond";
import "@fontsource-variable/eb-garamond/wght-italic.css";
import "../styles/global.css";

interface Props {
    title: string;
    description: string;
    /// How deep the "On this page" sidebar goes: 2 lists h2s only, 3 nests
    /// each h2's h3s beneath it (the default).
    tocDepth?: 2 | 3;
}

const { title, description, tocDepth = 3 } = Astro.props;

// The "On this page" sidebar is derived from the rendered content, so it
// works for markdown pages (whose headings already carry ids) and
// hand-written pages alike (ids are injected, GitHub-slug style). h2s with
// their h3s, shown when there's enough structure to navigate.
const html = await Astro.slots.render("default");
type Heading = { depth: number; id: string; html: string };
const headings: Heading[] = [];
const slugify = (text: string) =>
    text
        .toLowerCase()
        .replace(/&[a-z]+;|&#\d+;/g, "")
        .replace(/[^a-z0-9 -]/g, "")
        .trim()
        .replace(/\s+/g, "-");
const content = html.replace(
    /<h([23])([^>]*)>([\s\S]*?)<\/h\1>/g,
    (_m, depth, attrs, inner) => {
        const text = inner.replace(/<[^>]*>/g, "").trim();
        let id = (attrs.match(/id="([^"]+)"/) ?? [])[1];
        if (!id) {
            id = slugify(text);
            attrs += ` id="${id}"`;
        }
        headings.push({ depth: Number(depth), id, html: text });
        return `<h${depth}${attrs}>${inner}</h${depth}>`;
    },
);
// Group each h2 with the h3s that follow it (a leading orphan h3 is skipped).
type TocEntry = { id: string; html: string; children: Heading[] };
const toc: TocEntry[] = [];
for (const h of headings) {
    if (h.depth === 2) {
        toc.push({ id: h.id, html: h.html, children: [] });
    } else if (toc.length > 0 && h.depth <= tocDepth) {
        toc[toc.length - 1].children.push(h);
    }
}
const showToc = toc.length > 1;
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        <title>{title}</title>
        <meta name="description" content={description} />
        <link rel="icon" href="/favicon.png" type="image/png" />
        <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    </head>
    <body id="top">
        <header class="site-header">
            <div class="container">
                <a class="wordmark" href="/">Magritte</a>
                <nav>
                    <a href="/docs/config/">Configuration</a>
                    <a
                        href="https://github.com/lyallcooper/magritte"
                        aria-label="GitHub"
                        class="gh"
                    >
                        <svg
                            viewBox="0 0 16 16"
                            width="1.05em"
                            height="1.05em"
                            fill="currentColor"
                            aria-hidden="true"
                        >
                            <path
                                d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27s1.36.09 2 .27c1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0 0 16 8c0-4.42-3.58-8-8-8z"
                            ></path>
                        </svg>
                    </a>
                </nav>
            </div>
        </header>
        <main>
            <div class:list={["container", "page", { "with-toc": showToc }]}>
                {
                    showToc && (
                        <aside>
                            <script is:inline>
                                // Runs before the sidebar's content parses, so
                                // it can never flash before the checks below.
                                // The sidebar is exactly as wide as its text:
                                // hide it until the webfont settles (the swap
                                // would shift it), then show it iff it fits
                                // the margin beside the centered column.
                                (() => {
                                    const aside =
                                        document.currentScript.parentElement;
                                    const fit = () =>
                                        aside.classList.toggle(
                                            "clipped",
                                            aside.getBoundingClientRect().left <
                                                12,
                                        );
                                    if (
                                        document.fonts &&
                                        document.fonts.status !== "loaded"
                                    ) {
                                        aside.style.visibility = "hidden";
                                        Promise.race([
                                            document.fonts.ready,
                                            new Promise((r) =>
                                                setTimeout(r, 2000),
                                            ),
                                        ]).then(() => {
                                            fit();
                                            aside.style.visibility = "";
                                        });
                                    } else {
                                        addEventListener(
                                            "DOMContentLoaded",
                                            fit,
                                        );
                                    }
                                    addEventListener("resize", fit);
                                })();
                            </script>
                            <nav aria-label="On this page">
                                <p class="toc-title">
                                    {/* No title="Back to top" here: Fanboy's
                                        Annoyance List hides any anchor with
                                        that exact attribute. */}
                                    <a href="#top" aria-label="On this page — return to top">
                                        On this page
                                        <span class="top-arrow" aria-hidden="true">
                                            <svg
                                                viewBox="0 0 24 24"
                                                fill="none"
                                                stroke="currentColor"
                                                stroke-width="2.5"
                                                stroke-linecap="round"
                                                stroke-linejoin="round"
                                                ><path d="M12 22V4"></path><polyline
                                                    points="5 11 12 4 19 11"
                                                ></polyline></svg
                                            >
                                        </span>
                                    </a>
                                </p>
                                <ul>
                                    {toc.map((entry) => (
                                        <li>
                                            <a
                                                href={`#${entry.id}`}
                                                set:html={entry.html}
                                            />
                                            {entry.children.length > 0 && (
                                                <ul>
                                                    {entry.children.map((c) => (
                                                        <li>
                                                            <a
                                                                href={`#${c.id}`}
                                                                set:html={
                                                                    c.html
                                                                }
                                                            />
                                                        </li>
                                                    ))}
                                                </ul>
                                            )}
                                        </li>
                                    ))}
                                </ul>
                            </nav>
                        </aside>
                    )
                }
                <article set:html={content} />
            </div>
        </main>
    </body>
</html>

<style>
    /* The content column keeps the plain container's centered measure; the
       sidebar hangs in the margin beside it, so pages with and without a
       TOC line up. */
    .page.with-toc {
        position: relative;
    }

    .page.with-toc aside {
        position: absolute;
        top: 0;
        bottom: 0;
        right: 100%;
        width: max-content;
        max-width: 14rem;
        margin-right: 1.5rem;
    }

    /* Set by the fit-check script when the sidebar would run off the left
       edge of the window. visibility (not display) so it stays measurable. */
    .page.with-toc aside.clipped {
        visibility: hidden;
    }

    aside nav {
        position: sticky;
        top: 1.5rem;
        font-size: 0.95rem;
        line-height: 1.4;
    }

    .toc-title {
        margin: 0 0 0.5rem;
        font-weight: 600;
    }

    /* The title doubles as a back-to-top link. inline-block so the anchor
       is a reliable containing block for the arrow, sized to its text. */
    .toc-title a {
        display: inline-block;
        position: relative;
        color: var(--muted);
    }

    .toc-title a:hover {
        color: var(--accent);
        text-decoration: none;
    }

    /* Hangs in the gap beside the column so it never widens the sidebar
       (whose width — and fit check — track the widest text line). */
    .toc-title .top-arrow {
        position: absolute;
        left: 100%;
        /* Half-line centering sits slightly high against the lowercase-heavy
           title; bias a touch below the mathematical center. */
        top: 50%;
        transform: translateY(calc(-50% + 0.07em));
        margin-left: 0.35em;
    }

    .toc-title .top-arrow svg {
        display: block;
        width: 0.8em;
        height: 0.8em;
    }

    aside ul {
        list-style: none;
        margin: 0;
        padding: 0;
    }

    aside ul ul {
        padding-left: 0.9rem;
    }

    aside li {
        margin: 0.35rem 0;
    }

    aside a {
        color: var(--fg);
    }

    aside a:hover {
        color: var(--accent);
        text-decoration: none;
    }


    /* Sit the icon on the nav text's baseline. */
    .gh svg {
        vertical-align: -0.2em;
    }
</style>
